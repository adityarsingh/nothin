generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  PRO_PLUS
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Mood {
  VERY_LOW
  LOW
  NEUTRAL
  HIGH
  VERY_HIGH
}

enum MediaType {
  IMAGE
  VOICE
  FILE
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  plan           Plan      @default(FREE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  settings       UserSettings?
  journals       Journal[]
  entries        Entry[]
  tags           Tag[]
  people         Person[]
  exportLogs     ExportLog[]
}

model UserSettings {
  id               String  @id @default(cuid())
  userId           String  @unique
  theme            Theme   @default(SYSTEM)
  reminderEnabled        Boolean  @default(false)
  reminderTime           String?
  defaultJournalId       String?
  dismissedWeeklyReviews String[] @default([])

  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Journal {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String?
  icon        String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     Entry[]
}

model Entry {
  id         String   @id @default(cuid())
  journalId  String
  userId     String
  title      String?
  body       Json?
  bodyText   String?
  mood       Mood?
  place      String?
  isLocked   Boolean  @default(false)
  isPinned   Boolean  @default(false)
  isFavorite Boolean  @default(false)
  entryDate  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  journal    Journal           @relation(fields: [journalId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags       EntryTag[]
  people     EntryPerson[]
  media      MediaAttachment[]
}

model Tag {
  id         String   @id @default(cuid())
  userId     String
  name       String
  color      String?
  entryCount Int      @default(0)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries    EntryTag[]

  @@unique([userId, name])
}

model EntryTag {
  entryId String
  tagId   String

  entry   Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
}

model Person {
  id      String   @id @default(cuid())
  userId  String
  name    String

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries EntryPerson[]

  @@unique([userId, name])
}

model EntryPerson {
  entryId  String
  personId String

  entry    Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([entryId, personId])
}

model MediaAttachment {
  id        String    @id @default(cuid())
  entryId   String
  userId    String
  type      MediaType
  url       String
  filename  String
  size      Int
  mimeType  String
  createdAt DateTime  @default(now())

  entry     Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model ExportLog {
  id         String   @id @default(cuid())
  userId     String
  exportType String
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
